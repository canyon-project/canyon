{
  "name": "canyon-app",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run generate && vite build --mode client && vite build",
    "build:client": "vite build --mode client",
    "build:server": "vite build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "generate": "prisma generate",
    "seed:mock:users": "node ./scripts/seed-mock-users.mjs",
    "seed:mock:repos": "node ./scripts/seed-mock-repos.mjs",
    "postinstall": "npm run generate",
    "preinstall": "node ./scripts/check.mjs",
    "migrate:sql": "prisma migrate diff --from-empty --to-schema-datamodel ./prisma/schema.prisma --script > ./schema.sql"
  },
  "dependencies": {
    "@ant-design/icons": "6.1.0",
    "@canyonjs/git-provider": "0.0.6",
    "@canyonjs/report-component": "latest",
    "@canyonjs/report-html": "latest",
    "@hono/node-server": "^1.19.11",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.2.2",
    "@ibm/plex-mono": "^1.1.0",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/client": "6",
    "adm-zip": "^0.5.16",
    "ahooks": "^3.9.6",
    "antd": "6.1.0",
    "axios": "^1.14.0",
    "better-auth": "^1.6.9",
    "better-sqlite3": "^12.9.0",
    "canyon-data": "2.0.0-beta.36",
    "canyon-map": "2.0.0-beta.10",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "diff": "^8.0.3",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.2",
    "hono-history-api-fallback": "^0.0.2",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "monaco-editor": "0.55.1",
    "pg": "^8.18.0",
    "prisma": "6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-error-boundary": "^6.1.1",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.12.0",
    "tailwind-merge": "^3.5.0",
    "test-exclude": "^8.0.0",
    "tmp": "^0.2.5"
  },
  "devDependencies": {
    "@canyonjs/report": "latest",
    "@canyonjs/vite-plugin": "latest",
    "@hono/vite-build": "^1.10.0",
    "@hono/vite-dev-server": "^0.25.0",
    "@tailwindcss/vite": "4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.16.0",
    "@types/react": "19.2.3",
    "@types/react-dom": "19.2.3",
    "@types/test-exclude": "^6.0.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-istanbul": "4.1.3",
    "globals": "^16.5.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "8",
    "vite-plugin-istanbul": "latest",
    "vite-plugin-pages": "^0.33.3",
    "vitest": "4.1.3"
  }
}
