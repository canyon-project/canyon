{
  "name": "canyon-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run generate && vite build --mode client && vite build",
    "build:client": "vite build --mode client",
    "build:server": "vite build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "gen-coverage-report": "nyc report --reporter=@canyonjs/report --temp-dir=./.canyon_output",
    "test:e2e": "playwright test && npm run gen-coverage-report",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "generate": "prisma generate && prisma generate --schema prisma/schema-sqlite.prisma",
    "postinstall": "npm run generate",
    "preinstall": "node ./scripts/check.mjs",
    "migrate:sql": "prisma migrate diff --from-empty --to-schema-datamodel ./prisma/schema.prisma --script > ./schema.sql",
    "clean": "node scripts/clean.mjs"
  },
  "dependencies": {
    "@ant-design/icons": "catalog:",
    "@canyonjs/report-component": "catalog:",
    "@hono/node-server": "^1.19.11",
    "@hono/swagger-ui": "^0.6.0",
    "@hono/zod-openapi": "^1.2.2",
    "@ibm/plex-mono": "^1.1.0",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/client": "6",
    "adm-zip": "^0.5.16",
    "ahooks": "^3.9.6",
    "antd": "catalog:",
    "axios": "^1.13.5",
    "canyon-data": "2.0.0-beta.36",
    "canyon-map": "2.0.0-beta.10",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "diff": "^8.0.3",
    "dotenv": "catalog:",
    "hono": "^4.12.2",
    "hono-history-api-fallback": "0.0.1-beta.1",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "monaco-editor": "^0.55.1",
    "pg": "^8.18.0",
    "prisma": "6",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-error-boundary": "^6.1.1",
    "react-i18next": "^16.5.4",
    "react-router-dom": "catalog:",
    "tailwind-merge": "^3.5.0",
    "test-exclude": "^8.0.0",
    "tmp": "^0.2.5"
  },
  "devDependencies": {
    "@canyonjs/playwright": "^0.0.2",
    "@canyonjs/report": "catalog:",
    "@hono/vite-build": "^1.9.3",
    "@hono/vite-dev-server": "^0.25.0",
    "@playwright/test": "1.56.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "catalog:",
    "@types/pg": "^8.16.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/test-exclude": "^6.0.2",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "@vitest/coverage-istanbul": "catalog:",
    "globals": "catalog:",
    "nyc": "^18.0.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "simple-git-hooks": "^2.13.1",
    "swc-plugin-coverage-instrument": "^0.0.32",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "catalog:",
    "vite-plugin-pages": "^0.33.3",
    "vitest": "catalog:"
  },
  "simple-git-hooks": {
    "pre-commit": "npx nano-staged"
  },
  "nano-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "npm run lint:fix && npm run fmt"
  }
}
