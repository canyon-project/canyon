generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 以下是生成的，不要改！！！

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  @@unique([email])
  @@map("canyon_next_user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("canyon_next_session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("canyon_next_account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("canyon_next_verification")
}

// 以上是生成的，不要改！！！

// 更新
model Repo {
  id                String   @id
  provider          String
  pathWithNamespace String   @map("path_with_namespace")
  description       String
  config            String
  creator           String   @default("")
  createdAt         DateTime @map("created_at")
  updatedAt         DateTime @map("updated_at")
  members           RepoMember[]

  @@map("canyon_next_repo")
}

enum RepoMemberRole {
  admin
  developer
}

model RepoMember {
  id        String         @id @default(cuid())
  repoID    String         @map("repo_id")
  userID    String         @map("user_id")
  role      RepoMemberRole @default(developer)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  repo      Repo           @relation(fields: [repoID], references: [id], onDelete: Cascade)

  @@unique([repoID, userID])
  @@index([repoID])
  @@map("canyon_next_repo_member")
}

// 更新
model Commit {
  id      String @id
  content Json

  @@map("canyon_next_commit")
}

// 新增
// GitHub PR | GitLab Merge Request（PR/MR 信息，用于 pull/merge_requests 覆盖率）
model MergeRequest {
  id      String @id
  content Json

  @@map("canyon_next_merge_request")
}

model Diff {
  id        String   @id @default(cuid())
  provider  String
  repoID    String   @map("repo_id")
  from      String
  to        String
  path      String
  additions Int[]
  deletions Int[]
  subject   String
  subjectID String   @map("subject_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(3)

  @@map("canyon_next_diff")
}

model Infra {
  id                     String   @id
  name                   String
  value                  String   @db.Text
  createdAt              DateTime @default(now()) @map("createdOn")
  updatedAt              DateTime @updatedAt @map("updatedOn")
  isEncrypted            Boolean  @default(false) @map("isEncrypted")
  lastSyncedEnvFileValue String?  @map("lastSyncedEnvFileValue")

  @@map("canyon_next_infra_config")
}

model Coverage {
  // buildHash+sceneKey
  id            String @id
  // 包含buildProvider、buildID、branch等信息
  builds        Json
  // buildHash. instrumentCwd 不一样的话sourceMap解析也会有问题
  buildHash     String @map("build_hash")
  provider      String
  repoID        String @map("repo_id")
  sha           String
  buildTarget   String @map("build_target")
  instrumentCwd String @map("instrument_cwd")

  // sceneKey 场景
  sceneKey String @map("scene_key")
  // sceneKey = hash(
  // source +      // automation, manual, replay
  // type +        // e2e, unit, integration
  // env +         // test, staging, prod
  // trigger       // pipeline, schedule, manual
  // )
  scene    Json

  createdAt DateTime @map("created_at")
  updatedAt DateTime @map("updated_at")

  @@map("canyon_next_coverage")
}

model CoverageMapRelation {
  id                  String @id
  fullFilePath        String @map("full_file_path")
  restoreFullFilePath String @map("restore_full_file_path")
  // 唯一构建hash
  buildHash           String @map("build_hash")
  // 找coverageMap，减少存储
  coverageMapHash     String @map("coverage_map_hash")
  // 找sourceMap，减少存储
  sourceMapHash       String @map("source_map_hash")
  // 文件内容hash，未来多build合并提供依据
  fileContentHash     String @map("file_content_hash")

  @@map("canyon_next_coverage_map_relation")
}

model CoverageMap {
  hash      String   @id
  map       Bytes
  createdAt DateTime @map("created_at")

  @@map("canyon_next_coverage_map")
}

model CoverageSourceMap {
  hash      String @id
  sourceMap Bytes  @map("source_map")

  @@map("canyon_next_coverage_source_map")
}

model CoverageHit {
  id             String   @id
  buildHash      String   @map("build_hash")
  sceneKey       String   @map("scene_key")
  rawFilePath    String   @map("raw_file_path")
  s              Json
  f              Json
  b              Json
  inputSourceMap Int?     @map("input_source_map")
  createdAt      DateTime @map("created_at")

  @@map("canyon_next_coverage_hit")
}

/// POST /api/coverage/client 全量请求体 hash，用于幂等去重
model CoverageClientPayloadIdempotency {
  payloadHash String   @id @map("payload_hash")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("canyon_next_coverage_client_payload_idempotency")
}

model CoverageLock {
  coverageID String   @id @map("coverage_id")
  lockedAt   DateTime @map("locked_at")
  lockedBy   String   @map("locked_by")

  @@map("canyon_next_coverage_lock")
}

model CoverageSnapshot {
  id           Int      @id @default(autoincrement())
  provider     String
  repoID       String   @map("repo_id")
  subject      String
  subjectID    String   @map("subject_id")
  title        String?
  description  String?
  freezeTime   DateTime @map("freeze_time") @db.Timestamp(3)
  status       String
  artifactZip  Bytes    @map("artifact_zip")
  artifactSize Int      @map("artifact_size")
  createdBy    String   @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  finishedAt   DateTime @map("finished_at") @db.Timestamp(3)
  buildHash    String   @map("build_hash")
  buildTarget  String   @default("") @map("build_target")
  scene        Json
  statementsCovered      Int? @map("statements_covered")
  statementsTotal        Int? @map("statements_total")
  functionsCovered       Int? @map("functions_covered")
  functionsTotal         Int? @map("functions_total")
  branchesCovered        Int? @map("branches_covered")
  branchesTotal          Int? @map("branches_total")
  changestatementsCovered Int? @map("changestatements_covered")
  changestatementsTotal   Int? @map("changestatements_total")
  changefunctionsCovered  Int? @map("changefunctions_covered")
  changefunctionsTotal    Int? @map("changefunctions_total")
  changebranchesCovered   Int? @map("changebranches_covered")
  changebranchesTotal     Int? @map("changebranches_total")
  durationMs              Int? @map("duration_ms")
  /// 与 report-data.js 中 window.reportData（base64 gzip）对应的原始 gzip 字节，解压后为 JSON
  reportDataGzip          Bytes? @map("report_data_gzip")

  @@map("canyon_next_coverage_snapshot")
}
